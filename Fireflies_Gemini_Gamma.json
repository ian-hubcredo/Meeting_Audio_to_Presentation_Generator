    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst retryCount = ($node['Wait'].json.retryCount || 0) + 1;\n\nif (response.status === 'completed') {\n  return {\n    json: {\n      status: 'completed',\n      gammaUrl: response.gammaUrl,\n      exportUrl: response.exportUrl || response.pptxUrl,\n      generationId: response.generationId\n    }\n  };\n} else if (retryCount >= 20) {\n  throw new Error('Gamma generation timeout after 100 seconds');\n} else {\n  return {\n    json: {\n      status: 'processing',\n      generationId: response.generationId,\n      retryCount: retryCount\n    }\n  };\n}"
      },
      "id": "8af3a7d2-d15b-4880-8041-6918aca5fb8c",
