        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"inputText\": {{ $json.inputText }},\n  \"textMode\": \"preserve\",\n  \"format\": \"presentation\",\n  \"themeName\": \"Oasis\",\n  \"numberOfCards\": 10,\n  \"exportAs\": \"pptx\"\n}",
        "options": {}
      },
      "id": "2ac5003b-50f0-4e45-a3d9-69df13b36ecf",
