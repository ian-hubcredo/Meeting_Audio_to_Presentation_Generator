{
  "name": "Fireflies → Gemini → Gamma",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst meetingContent = `# ${data.title || 'Meeting Notes'}\n\n## Meeting Details\n- Date: ${data.date || new Date().toISOString().split('T')[0]}\n- Duration: ${data.duration ? Math.round(data.duration / 60) + ' minutes' : 'N/A'}\n- Participants: ${data.participants?.map(p => p.name).join(', ') || 'Not specified'}\n\n## Summary\n${data.summary?.overview || data.summary?.short_summary || 'No summary available'}\n\n## Key Topics\n${data.topics?.map(t => `- ${t.topic}`).join('\\n') || 'None'}\n\n## Action Items\n${data.action_items?.map(item => `- ${item.assignee || 'Unassigned'}: ${item.text}`).join('\\n') || 'None'}\n\n## Transcript Highlights\n${data.sentences?.slice(0, 50).map(s => `**${s.speaker_name}**: ${s.text}`).join('\\n\\n') || 'No transcript available'}`;\n\nreturn {\n  json: {\n    inputText: meetingContent\n  }\n};"
      },
      "id": "0b7c129b-12ff-4913-a292-f06e836f7a8b",
      "name": "Structure Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
